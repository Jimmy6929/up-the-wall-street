#!/usr/bin/env bash
# verify - the single "can this repo still be trusted?" gate.
#
# Blocking (exit 1 on failure): the unit-test suites (both roots), the bulk
# schema/provenance gate over every research/*.data.json, and the generated-index
# freshness check (research/INDEX.md must match its sources). Advisory (never
# blocks): the markdown source/as-of coverage check, run with --warn-only so its
# findings print but a young checker can't block work before it's tuned. Promote
# it to blocking by dropping --warn-only once it's proven low-noise.
#
# Usage:  scripts/verify        (run from anywhere; it cd's to the repo root)
set -euo pipefail
cd "$(dirname "$0")/.."
SCRIPTS=".claude/skills/research/scripts"

echo "== unittest: research scripts =="
python3 -m unittest discover -s "$SCRIPTS" -p 'test_*.py'

echo "== unittest: tests/ =="
python3 -m unittest discover -s tests -p 'test_*.py'      # split root (test_book_map.py)

echo "== schema/provenance gate: research/*.data.json =="
python3 "$SCRIPTS/validate_data.py" research/*.data.json

echo "== research index freshness (blocking; research/INDEX.md is generated) =="
python3 "$SCRIPTS/build_index.py" --check

echo "== markdown source/as-of coverage (advisory) =="
# lessons.md and alerts.md are append-only ledgers, INDEX.md is generated - not research notes
python3 "$SCRIPTS/check_research_markdown.py" --warn-only $(ls research/*.md | grep -vE '^research/(lessons|alerts|INDEX)\.md$')

echo "== note staleness (advisory; Lynch rechecks the story every few months) =="
python3 - <<'PY'
import datetime, glob, re
STALE_DAYS = 100
today = datetime.date.today()
for path in sorted(glob.glob("research/*.md")):
    if path.endswith(("lessons.md", "alerts.md", "INDEX.md")):   # ledgers + generated index, not notes
        continue
    m = re.search(r"^reviewed:\s*(\d{4}-\d{2}-\d{2})", open(path).read(), re.MULTILINE)
    if not m:
        print(f"  WARN {path}: no 'reviewed:' date in frontmatter")
        continue
    age = (today - datetime.date.fromisoformat(m.group(1))).days
    if age > STALE_DAYS:
        print(f"  WARN {path}: last rechecked {age} days ago - run /recheck")
print("  (advisory only)")
PY

echo "== research evals (advisory; the expensive gate is scripts/evals) =="
if [ -f evals/scores.tsv ]; then
  echo "  last score: $(tail -n 1 evals/scores.tsv)"
else
  echo "  no eval scores recorded yet - run scripts/evals --smoke"
fi

echo
echo "ALL BLOCKING CHECKS PASSED"
